# ===== HOMES-Engine Environment Variables =====
# Copie este arquivo para .env e preencha seus dados

# API Keys
GEMINI_API_KEY=sua_chave_gemini_aqui
GOOGLE_CLOUD_TTS_API_KEY=sua_chave_tts_aqui

# Termux API
USE_TERMUX_API=true
USE_VOICE_INPUT=false

# Video Settings
VIDEO_DURATION_SECONDS=60
VIDEO_FPS=30

# Theme (yellow_punch, cyan_future, minimal_box)
DEFAULT_THEME=yellow_punch

# Language
TTS_LANGUAGE=pt-BR

# Hosted VideoLM renderer used by the reviewer demo
VIDEOLM_URL=https://54-162-84-165.sslip.io
VIDEOLM_ASSEMBLE_PATH=
VIDEOLM_POLL_INTERVAL=5
VIDEOLM_POLL_TIMEOUT=600
